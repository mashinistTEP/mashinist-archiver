<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1A0033">
    
    <!-- Заголовок -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#9C27B0"
        android:padding="16dp"
        android:gravity="center">
        
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🚂 MASHINIST ARCHIVER"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"/>
    </LinearLayout>
    
    <!-- Путь -->
    <TextView
        android:id="@+id/pathText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#4A148C"
        android:padding="12dp"
        android:text="/storage/emulated/0"
        android:textColor="#E1BEE7"
        android:textSize="12sp"/>
    
    <!-- Кнопки -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:background="#6A1B9A">
        
        <Button
            android:id="@+id/createArchiveBtn"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:text="📦 Создать архив"
            android:textColor="#FFFFFF"
            android:backgroundTint="#AB47BC"/>
        
        <Button
            android:id="@+id/extractArchiveBtn"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:text="📂 Распаковать"
            android:textColor="#FFFFFF"
            android:backgroundTint="#8E24AA"/>
    </LinearLayout>
    
    <!-- Список файлов -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#2D004D"/>
    
</LinearLayout>
