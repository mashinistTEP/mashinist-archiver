<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#2D004D">
    
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Настройки"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>
    
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Формат по умолчанию:"
        android:textColor="#CE93D8"
        android:textSize="14sp"
        android:layout_marginBottom="8dp"/>
    
    <RadioGroup
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp">
        <RadioButton android:id="@+id/radioDefaultMashinist" android:layout_width="match_parent" android:layout_height="wrap_content" android:text=".mashinist" android:textColor="#FFFFFF" android:buttonTint="#CE93D8" android:checked="true" android:padding="8dp"/>
        <RadioButton android:id="@+id/radioDefaultTep70bs" android:layout_width="match_parent" android:layout_height="wrap_content" android:text=".tep70bs" android:textColor="#FFFFFF" android:buttonTint="#CE93D8" android:padding="8dp"/>
        <RadioButton android:id="@+id/radioDefaultTep" android:layout_width="match_parent" android:layout_height="wrap_content" android:text=".tep" android:textColor="#FFFFFF" android:buttonTint="#CE93D8" android:padding="8dp"/>
    </RadioGroup>
    
    <Button android:id="@+id/saveSettingsBtn" android:layout_width="match_parent" android:layout_height="48dp" android:text="Сохранить" android:textColor="#FFFFFF" android:backgroundTint="#9C27B0" android:layout_marginBottom="8dp"/>
    <Button android:id="@+id/closeSettingsBtn" android:layout_width="match_parent" android:layout_height="48dp" android:text="Закрыть" android:textColor="#FFFFFF" android:backgroundTint="#424242"/>
    
</LinearLayout>
